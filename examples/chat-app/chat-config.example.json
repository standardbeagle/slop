{
  "model": "claude-sonnet",
  "max_tokens": 4096,
  "temperature": 0.7,
  "scripts_dir": "scripts",
  "mcp_servers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"],
      "transport": "stdio"
    },
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@anthropics/mcp-server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "your-api-key-here"
      },
      "transport": "stdio"
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@anthropics/mcp-server-github"],
      "env": {
        "GITHUB_TOKEN": "your-github-token-here"
      },
      "transport": "stdio"
    }
  }
}

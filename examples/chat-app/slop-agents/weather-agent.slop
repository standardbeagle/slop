# Weather Agent - Weather information and MCP integration patterns

user_msg = user_message
response = ""

# Note: This agent demonstrates MCP integration patterns
# In a real deployment, you would connect to a weather MCP service

if "forecast" in lower(user_msg):
    emit("Weather Forecast Patterns:\n\n")
    emit("**Getting forecast with MCP:**\n")
    emit("```slop\n")
    emit("# Connect to weather service\n")
    emit("@use(weather: 'mcp/weather@v1')\n\n")
    emit("# Get 7-day forecast\n")
    emit("forecast = weather.get_forecast({location: 'Seattle, WA', days: 7})\n\n")
    emit("# Display each day\n")
    emit("for day in get(forecast, 'daily'):\n")
    emit("  emit(format('{}: {} - {}/{}', get(day, 'date'), get(day, 'condition'), get(day, 'high'), get(day, 'low')))\n")
    emit("```\n\n")
    emit("Example output:\n")
    emit("**7-Day Forecast for Seattle, WA**\n")
    emit("- Mon: Partly Cloudy - 62/48\n")
    emit("- Tue: Sunny - 68/52\n")
    emit("- Wed: Rain - 55/45\n")
    emit("- Thu: Cloudy - 58/47")

elif "current" in lower(user_msg) or "now" in lower(user_msg) or "today" in lower(user_msg):
    emit("Getting Current Weather:\n\n")
    emit("**MCP pattern:**\n")
    emit("```slop\n")
    emit("@use(weather: 'mcp/weather@v1')\n\n")
    emit("current = weather.get_current({location: user_location})\n\n")
    emit("emit(format('Temperature: {}F ({}C)', get(current, 'temp_f'), get(current, 'temp_c')))\n")
    emit("emit(format('Wind: {} mph {}', get(current, 'wind_speed'), get(current, 'wind_dir')))\n")
    emit("emit(format('Humidity: {}%', get(current, 'humidity')))\n")
    emit("```\n\n")
    emit("Example output:\n")
    emit("**Current Weather in Seattle**\n")
    emit("- Temperature: 58F (14C)\n")
    emit("- Condition: Partly Cloudy\n")
    emit("- Wind: 8 mph NW\n")
    emit("- Humidity: 65%\n")
    emit("- UV Index: 3 (Moderate)")

elif "alert" in lower(user_msg) or "warning" in lower(user_msg):
    emit("Weather Alerts Pattern:\n\n")
    emit("**Checking for alerts:**\n")
    emit("```slop\n")
    emit("@use(weather: 'mcp/weather@v1')\n\n")
    emit("alerts = weather.get_alerts({location: user_location, severity: 'all'})\n\n")
    emit("if len(alerts) > 0:\n")
    emit("  for alert in alerts:\n")
    emit("    emit(format('WARNING: {} - {}', get(alert, 'type'), get(alert, 'headline')))\n")
    emit("    emit(get(alert, 'description'))\n")
    emit("else:\n")
    emit("  emit('No active weather alerts')\n")
    emit("```\n\n")
    emit("Example alerts:\n")
    emit("**Winter Storm Warning**\n")
    emit("Heavy snow expected tonight through tomorrow\n")
    emit("Accumulation: 8-12 inches possible")

elif "temperature" in lower(user_msg) or "convert" in lower(user_msg):
    emit("Temperature Conversion:\n\n")
    emit("**Fahrenheit to Celsius:**\n")
    emit("```\n")
    emit("celsius = (fahrenheit - 32) * 5 / 9\n")
    emit("```\n\n")
    emit("**Celsius to Fahrenheit:**\n")
    emit("```\n")
    emit("fahrenheit = celsius * 9 / 5 + 32\n")
    emit("```\n\n")
    emit("**Quick reference:**\n")
    emit("- 32F = 0C (Freezing)\n")
    emit("- 50F = 10C (Cool)\n")
    emit("- 68F = 20C (Room temp)\n")
    emit("- 77F = 25C (Warm)\n")
    emit("- 86F = 30C (Hot)\n")
    emit("- 100F = 38C (Very hot)")

elif "humidity" in lower(user_msg) or "moisture" in lower(user_msg):
    emit("Humidity Information:\n\n")
    emit("**Humidity levels:**\n")
    emit("- 0-30%: Dry - May cause dry skin\n")
    emit("- 30-50%: Comfortable range\n")
    emit("- 50-60%: Slightly humid\n")
    emit("- 60-70%: Humid\n")
    emit("- 70%+: Very humid - muggy feeling\n\n")
    emit("**In SLOP:**\n")
    emit("```\n")
    emit("humidity = get(weather_data, 'humidity')\n\n")
    emit("if humidity < 30:\n")
    emit("  comfort = 'dry'\n")
    emit("elif humidity < 60:\n")
    emit("  comfort = 'comfortable'\n")
    emit("else:\n")
    emit("  comfort = 'humid'\n")
    emit("```")

elif "wind" in lower(user_msg):
    emit("Wind Information:\n\n")
    emit("**Beaufort Scale (simplified):**\n")
    emit("- 0-3 mph: Calm\n")
    emit("- 4-7 mph: Light breeze\n")
    emit("- 8-12 mph: Gentle breeze\n")
    emit("- 13-18 mph: Moderate wind\n")
    emit("- 19-24 mph: Fresh wind\n")
    emit("- 25-31 mph: Strong wind\n")
    emit("- 32-38 mph: Near gale\n")
    emit("- 39+ mph: Gale/Storm\n\n")
    emit("**Wind direction:**\n")
    emit("- N, NE, E, SE, S, SW, W, NW\n")
    emit("- Degrees: 0=N, 90=E, 180=S, 270=W")

elif "rain" in lower(user_msg) or "precipitation" in lower(user_msg):
    emit("Precipitation Information:\n\n")
    emit("**Rain intensity:**\n")
    emit("- Light: < 0.1 in/hr (< 2.5 mm/hr)\n")
    emit("- Moderate: 0.1-0.3 in/hr (2.5-7.6 mm/hr)\n")
    emit("- Heavy: > 0.3 in/hr (> 7.6 mm/hr)\n\n")
    emit("**Probability of precipitation:**\n")
    emit("```\n")
    emit("pop = get(forecast, 'precipitation_chance')\n\n")
    emit("if pop >= 80:\n")
    emit("  emit('Rain very likely - bring umbrella!')\n")
    emit("elif pop >= 50:\n")
    emit("  emit('Rain possible - consider umbrella')\n")
    emit("elif pop >= 20:\n")
    emit("  emit('Slight chance of rain')\n")
    emit("else:\n")
    emit("  emit('Rain unlikely')\n")
    emit("```")

elif "uv" in lower(user_msg) or "sun" in lower(user_msg):
    emit("UV Index Information:\n\n")
    emit("**UV Index Scale:**\n")
    emit("- 0-2: Low - Minimal protection needed\n")
    emit("- 3-5: Moderate - Some protection\n")
    emit("- 6-7: High - Protection essential\n")
    emit("- 8-10: Very High - Extra protection\n")
    emit("- 11+: Extreme - Avoid midday sun\n\n")
    emit("**Recommendations by level:**\n")
    emit("```\n")
    emit("uv = get(weather, 'uv_index')\n\n")
    emit("if uv >= 8:\n")
    emit("  emit('SPF 30+, seek shade, wear hat')\n")
    emit("elif uv >= 6:\n")
    emit("  emit('SPF 30, limit midday exposure')\n")
    emit("elif uv >= 3:\n")
    emit("  emit('SPF 15-30 recommended')\n")
    emit("else:\n")
    emit("  emit('Low risk from sun')\n")
    emit("```")

else:
    emit("I'm your Weather Agent!\n\n")
    emit("I can help with weather-related information:\n")
    emit("- **Current weather** - Temperature, conditions now\n")
    emit("- **Forecast** - Multi-day predictions\n")
    emit("- **Alerts** - Warnings and advisories\n")
    emit("- **Temperature** - Conversions and ranges\n")
    emit("- **Humidity** - Comfort levels\n")
    emit("- **Wind** - Speed and direction info\n")
    emit("- **Precipitation** - Rain and snow\n")
    emit("- **UV Index** - Sun protection\n\n")
    emit("I also demonstrate MCP integration patterns!\n\n")
    emit("What weather information do you need?")

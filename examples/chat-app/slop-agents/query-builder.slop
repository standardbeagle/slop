# Query Builder - SQL query construction assistant

user_msg = user_message
response = ""

# Detect SQL query patterns

if "select" in lower(user_msg) and ("all" in lower(user_msg) or "*" in user_msg):
    emit("SELECT All Columns:\n\n")
    emit("**Basic syntax:**\n")
    emit("```sql\n")
    emit("SELECT * FROM table_name;\n")
    emit("```\n\n")
    emit("**With condition:**\n")
    emit("```sql\n")
    emit("SELECT * FROM users WHERE active = true;\n")
    emit("```\n\n")
    emit("**With limit:**\n")
    emit("```sql\n")
    emit("SELECT * FROM orders LIMIT 100;\n")
    emit("```\n\n")
    emit("**Best practice:** Avoid SELECT * in production - specify columns explicitly for better performance.")

elif "where" in lower(user_msg) or "filter" in lower(user_msg) or "condition" in lower(user_msg):
    emit("WHERE Clause Patterns:\n\n")
    emit("**Equality:**\n")
    emit("```sql\n")
    emit("WHERE status = 'active'\n")
    emit("WHERE age = 25\n")
    emit("```\n\n")
    emit("**Comparison:**\n")
    emit("```sql\n")
    emit("WHERE age > 18\n")
    emit("WHERE price <= 100.00\n")
    emit("WHERE created_at >= '2024-01-01'\n")
    emit("```\n\n")
    emit("**Multiple conditions:**\n")
    emit("```sql\n")
    emit("WHERE status = 'active' AND role = 'admin'\n")
    emit("WHERE category = 'books' OR category = 'music'\n")
    emit("WHERE NOT deleted\n")
    emit("```\n\n")
    emit("**Pattern matching:**\n")
    emit("```sql\n")
    emit("WHERE name LIKE 'John%'      -- Starts with John\n")
    emit("WHERE email LIKE '%@gmail.com'  -- Ends with @gmail.com\n")
    emit("WHERE title LIKE '%SQL%'    -- Contains SQL\n")
    emit("```\n\n")
    emit("**IN clause:**\n")
    emit("```sql\n")
    emit("WHERE status IN ('pending', 'processing', 'shipped')\n")
    emit("```")

elif "join" in lower(user_msg):
    emit("JOIN Patterns:\n\n")
    emit("**INNER JOIN (matching rows only):**\n")
    emit("```sql\n")
    emit("SELECT o.id, c.name, o.total\n")
    emit("FROM orders o\n")
    emit("INNER JOIN customers c ON o.customer_id = c.id;\n")
    emit("```\n\n")
    emit("**LEFT JOIN (all from left + matching):**\n")
    emit("```sql\n")
    emit("SELECT c.name, o.id\n")
    emit("FROM customers c\n")
    emit("LEFT JOIN orders o ON c.id = o.customer_id;\n")
    emit("```\n\n")
    emit("**Multiple joins:**\n")
    emit("```sql\n")
    emit("SELECT o.id, c.name, p.title\n")
    emit("FROM orders o\n")
    emit("JOIN customers c ON o.customer_id = c.id\n")
    emit("JOIN products p ON o.product_id = p.id;\n")
    emit("```\n\n")
    emit("**Join types:**\n")
    emit("- INNER - Only matching rows\n")
    emit("- LEFT - All left + matching right\n")
    emit("- RIGHT - Matching left + all right\n")
    emit("- FULL - All from both tables")

elif "group" in lower(user_msg) or "aggregate" in lower(user_msg):
    emit("GROUP BY and Aggregation:\n\n")
    emit("**Basic grouping:**\n")
    emit("```sql\n")
    emit("SELECT category, COUNT(*) as count\n")
    emit("FROM products\n")
    emit("GROUP BY category;\n")
    emit("```\n\n")
    emit("**With aggregates:**\n")
    emit("```sql\n")
    emit("SELECT customer_id, COUNT(*) as order_count, SUM(total) as total_spent, AVG(total) as avg_order, MIN(total) as min_order, MAX(total) as max_order\n")
    emit("FROM orders\n")
    emit("GROUP BY customer_id;\n")
    emit("```\n\n")
    emit("**With HAVING (filter groups):**\n")
    emit("```sql\n")
    emit("SELECT category, COUNT(*) as count\n")
    emit("FROM products\n")
    emit("GROUP BY category\n")
    emit("HAVING COUNT(*) > 10;\n")
    emit("```")

elif "order" in lower(user_msg) or "sort" in lower(user_msg):
    emit("ORDER BY Patterns:\n\n")
    emit("**Ascending (default):**\n")
    emit("```sql\n")
    emit("SELECT * FROM users ORDER BY name;\n")
    emit("SELECT * FROM users ORDER BY name ASC;\n")
    emit("```\n\n")
    emit("**Descending:**\n")
    emit("```sql\n")
    emit("SELECT * FROM orders ORDER BY created_at DESC;\n")
    emit("```\n\n")
    emit("**Multiple columns:**\n")
    emit("```sql\n")
    emit("SELECT * FROM products\n")
    emit("ORDER BY category ASC, price DESC;\n")
    emit("```\n\n")
    emit("**With LIMIT:**\n")
    emit("```sql\n")
    emit("-- Top 10 highest orders\n")
    emit("SELECT * FROM orders\n")
    emit("ORDER BY total DESC\n")
    emit("LIMIT 10;\n")
    emit("```")

elif "insert" in lower(user_msg) or "add" in lower(user_msg):
    emit("INSERT Patterns:\n\n")
    emit("**Single row:**\n")
    emit("```sql\n")
    emit("INSERT INTO users (name, email, created_at)\n")
    emit("VALUES ('John Doe', 'john@example.com', NOW());\n")
    emit("```\n\n")
    emit("**Multiple rows:**\n")
    emit("```sql\n")
    emit("INSERT INTO products (name, price)\n")
    emit("VALUES ('Widget A', 19.99), ('Widget B', 29.99), ('Widget C', 39.99);\n")
    emit("```\n\n")
    emit("**Insert from SELECT:**\n")
    emit("```sql\n")
    emit("INSERT INTO archived_orders (id, total, created_at)\n")
    emit("SELECT id, total, created_at\n")
    emit("FROM orders\n")
    emit("WHERE status = 'completed'\n")
    emit("AND created_at < '2024-01-01';\n")
    emit("```")

elif "update" in lower(user_msg) or "modify" in lower(user_msg):
    emit("UPDATE Patterns:\n\n")
    emit("**Single column:**\n")
    emit("```sql\n")
    emit("UPDATE users\n")
    emit("SET status = 'inactive'\n")
    emit("WHERE last_login < '2024-01-01';\n")
    emit("```\n\n")
    emit("**Multiple columns:**\n")
    emit("```sql\n")
    emit("UPDATE products\n")
    emit("SET price = price * 1.10, updated_at = NOW()\n")
    emit("WHERE category = 'electronics';\n")
    emit("```\n\n")
    emit("**With subquery:**\n")
    emit("```sql\n")
    emit("UPDATE orders\n")
    emit("SET discount = 0.10\n")
    emit("WHERE customer_id IN (SELECT id FROM customers WHERE tier = 'gold');\n")
    emit("```\n\n")
    emit("**Always use WHERE** to avoid updating all rows!")

elif "delete" in lower(user_msg) or "remove" in lower(user_msg):
    emit("DELETE Patterns:\n\n")
    emit("**Basic delete:**\n")
    emit("```sql\n")
    emit("DELETE FROM orders\n")
    emit("WHERE status = 'cancelled';\n")
    emit("```\n\n")
    emit("**Delete old records:**\n")
    emit("```sql\n")
    emit("DELETE FROM logs\n")
    emit("WHERE created_at < NOW() - INTERVAL '30 days';\n")
    emit("```\n\n")
    emit("**Soft delete (preferred):**\n")
    emit("```sql\n")
    emit("UPDATE users\n")
    emit("SET deleted_at = NOW(), active = false\n")
    emit("WHERE id = 123;\n")
    emit("```\n\n")
    emit("**Always use WHERE** - DELETE without WHERE removes all rows!\n")
    emit("**Best practice:** Use soft deletes for important data.")

elif "index" in lower(user_msg) or "performance" in lower(user_msg):
    emit("Index and Performance:\n\n")
    emit("**Create index:**\n")
    emit("```sql\n")
    emit("CREATE INDEX idx_users_email ON users(email);\n")
    emit("CREATE INDEX idx_orders_date ON orders(created_at DESC);\n")
    emit("```\n\n")
    emit("**Composite index:**\n")
    emit("```sql\n")
    emit("CREATE INDEX idx_orders_customer_date\n")
    emit("ON orders(customer_id, created_at);\n")
    emit("```\n\n")
    emit("**When to use indexes:**\n")
    emit("- Columns in WHERE clauses\n")
    emit("- Columns in JOIN conditions\n")
    emit("- Columns in ORDER BY\n")
    emit("- Columns with high cardinality\n\n")
    emit("**Avoid on:**\n")
    emit("- Columns with few unique values\n")
    emit("- Tables with heavy INSERT/UPDATE\n")
    emit("- Very small tables")

elif "subquery" in lower(user_msg) or "nested" in lower(user_msg):
    emit("Subquery Patterns:\n\n")
    emit("**In WHERE:**\n")
    emit("```sql\n")
    emit("SELECT * FROM orders\n")
    emit("WHERE customer_id IN (SELECT id FROM customers WHERE country = 'USA');\n")
    emit("```\n\n")
    emit("**Correlated subquery:**\n")
    emit("```sql\n")
    emit("SELECT * FROM orders o\n")
    emit("WHERE total > (SELECT AVG(total) FROM orders WHERE customer_id = o.customer_id);\n")
    emit("```\n\n")
    emit("**In SELECT (scalar):**\n")
    emit("```sql\n")
    emit("SELECT name, (SELECT COUNT(*) FROM orders WHERE customer_id = c.id) as order_count\n")
    emit("FROM customers c;\n")
    emit("```")

else:
    emit("I'm your Query Builder!\n\n")
    emit("I can help you construct SQL queries:\n")
    emit("- **SELECT** - Retrieving data\n")
    emit("- **WHERE** - Filtering conditions\n")
    emit("- **JOIN** - Combining tables\n")
    emit("- **GROUP BY** - Aggregation\n")
    emit("- **ORDER BY** - Sorting results\n")
    emit("- **INSERT** - Adding records\n")
    emit("- **UPDATE** - Modifying data\n")
    emit("- **DELETE** - Removing records\n")
    emit("- **Indexes** - Performance optimization\n")
    emit("- **Subqueries** - Nested queries\n\n")
    emit("What kind of query do you need help with?")

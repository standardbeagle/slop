# Task Helper - Task and todo management assistant

user_msg = user_message
response = ""

# Detect task management actions

if "add" in lower(user_msg) and ("task" in lower(user_msg) or "todo" in lower(user_msg)):
    emit("To add a new task:\n\n")
    emit("**Quick add:**\n")
    emit("```\n")
    emit("tasks = append(tasks, {title: 'Your task title', status: 'pending', created: now()})\n")
    emit("```\n\n")
    emit("**With priority:**\n")
    emit("```\n")
    emit("tasks = append(tasks, {title: 'Important task', status: 'pending', priority: 'high', due_date: '2024-12-31'})\n")
    emit("```\n\n")
    emit("What task would you like to add?")

elif "complete" in lower(user_msg) or "done" in lower(user_msg) or "finish" in lower(user_msg):
    emit("Marking tasks complete:\n\n")
    emit("**Update single task:**\n")
    emit("```\n")
    emit("tasks = map(tasks, (t) -> if get(t, 'id') == task_id: merge(t, {status: 'completed', completed_at: now()}) else: t)\n")
    emit("```\n\n")
    emit("**Filter completed:**\n")
    emit("```\n")
    emit("completed = filter(tasks, (t) -> get(t, 'status') == 'completed')\n")
    emit("pending = reject(tasks, (t) -> get(t, 'status') == 'completed')\n")
    emit("```\n\n")
    emit("Which task did you complete?")

elif "list" in lower(user_msg) or "show" in lower(user_msg) or "view" in lower(user_msg):
    emit("Listing and viewing tasks:\n\n")
    emit("**All tasks:**\n")
    emit("```\n")
    emit("for task in tasks:\n")
    emit("  emit(format('[{}] {} - {}', get(task, 'status'), get(task, 'title'), get(task, 'priority')))\n")
    emit("```\n\n")
    emit("**Pending only:**\n")
    emit("```\n")
    emit("pending = filter(tasks, (t) -> get(t, 'status') == 'pending')\n")
    emit("```\n\n")
    emit("**By priority:**\n")
    emit("```\n")
    emit("high_priority = filter(tasks, (t) -> get(t, 'priority') == 'high')\n")
    emit("```")

elif "priority" in lower(user_msg) or "prioritize" in lower(user_msg):
    emit("Managing task priorities:\n\n")
    emit("**Priority levels:**\n")
    emit("- High - Urgent, do first\n")
    emit("- Medium - Important, schedule soon\n")
    emit("- Low - Nice to have, when time permits\n\n")
    emit("**Sort by priority:**\n")
    emit("```\n")
    emit("priority_order = {high: 0, medium: 1, low: 2}\n")
    emit("sorted_tasks = sorted(tasks, key: (t) -> get(priority_order, get(t, 'priority'), 99))\n")
    emit("```\n\n")
    emit("**Change priority:**\n")
    emit("```\n")
    emit("task = merge(task, {priority: 'high'})\n")
    emit("```")

elif "due" in lower(user_msg) or "deadline" in lower(user_msg) or "schedule" in lower(user_msg):
    emit("Managing due dates:\n\n")
    emit("**Set due date:**\n")
    emit("```\n")
    emit("task = merge(task, {due_date: '2024-12-31'})\n")
    emit("```\n\n")
    emit("**Find overdue:**\n")
    emit("```\n")
    emit("today = today()\n")
    emit("overdue = filter(tasks, (t) -> get(t, 'due_date') < today and get(t, 'status') != 'completed')\n")
    emit("```\n\n")
    emit("**Due this week:**\n")
    emit("```\n")
    emit("week_end = time_add(today(), '7d')\n")
    emit("this_week = filter(tasks, (t) -> get(t, 'due_date') <= week_end)\n")
    emit("```")

elif "delete" in lower(user_msg) or "remove" in lower(user_msg):
    emit("Removing tasks:\n\n")
    emit("**Remove by ID:**\n")
    emit("```\n")
    emit("tasks = reject(tasks, (t) -> get(t, 'id') == task_id)\n")
    emit("```\n\n")
    emit("**Clear completed:**\n")
    emit("```\n")
    emit("tasks = reject(tasks, (t) -> get(t, 'status') == 'completed')\n")
    emit("```\n\n")
    emit("**Archive old tasks:**\n")
    emit("```\n")
    emit("cutoff = time_add(today(), '-30d')  # 30 days ago\n")
    emit("archived = filter(tasks, (t) -> get(t, 'completed_at') < cutoff)\n")
    emit("tasks = reject(tasks, (t) -> get(t, 'completed_at') < cutoff)\n")
    emit("```")

elif "search" in lower(user_msg) or "find" in lower(user_msg):
    emit("Searching tasks:\n\n")
    emit("**By title:**\n")
    emit("```\n")
    emit("matches = filter(tasks, (t) -> contains(lower(get(t, 'title')), 'keyword'))\n")
    emit("```\n\n")
    emit("**By tag:**\n")
    emit("```\n")
    emit("tagged = filter(tasks, (t) -> 'work' in get(t, 'tags', []))\n")
    emit("```\n\n")
    emit("**First match:**\n")
    emit("```\n")
    emit("found = find(tasks, (t) -> get(t, 'id') == target_id)\n")
    emit("```")

elif "summary" in lower(user_msg) or "stats" in lower(user_msg) or "overview" in lower(user_msg):
    emit("Task summary statistics:\n\n")
    emit("**Counts:**\n")
    emit("```\n")
    emit("total = len(tasks)\n")
    emit("completed = len(filter(tasks, (t) -> get(t, 'status') == 'completed'))\n")
    emit("pending = total - completed\n")
    emit("completion_rate = (completed / total) * 100\n")
    emit("```\n\n")
    emit("**By priority:**\n")
    emit("```\n")
    emit("by_priority = group_by(tasks, (t) -> get(t, 'priority'))\n")
    emit("high_count = len(get(by_priority, 'high', []))\n")
    emit("```\n\n")
    emit("Example output:\n")
    emit("**Task Summary**\n")
    emit("- Total: 25 tasks\n")
    emit("- Completed: 18 (72%)\n")
    emit("- Pending: 7\n")
    emit("- High priority: 3\n")
    emit("- Overdue: 1")

else:
    emit("I'm your Task Helper!\n\n")
    emit("I can help you manage tasks and todos:\n")
    emit("- **Add tasks** - Create new todo items\n")
    emit("- **Complete tasks** - Mark items done\n")
    emit("- **List tasks** - View pending and completed\n")
    emit("- **Set priorities** - High, medium, low\n")
    emit("- **Due dates** - Schedule and track deadlines\n")
    emit("- **Search** - Find specific tasks\n")
    emit("- **Summary** - Get overview statistics\n\n")
    emit("What would you like to do with your tasks?")

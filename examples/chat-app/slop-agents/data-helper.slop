# Data Helper - Data transformation and manipulation assistant

user_msg = user_message
response = ""

# Data format detection and conversion

if "json" in lower(user_msg) and "csv" in lower(user_msg):
    emit("Converting between JSON and CSV:\n\n")
    emit("**JSON to CSV:**\n")
    emit("```\n")
    emit("[\n")
    emit("  {\"name\": \"Alice\", \"age\": 30},\n")
    emit("  {\"name\": \"Bob\", \"age\": 25}\n")
    emit("]\n")
    emit("```\n")
    emit("Becomes:\n")
    emit("```csv\n")
    emit("name,age\n")
    emit("Alice,30\n")
    emit("Bob,25\n")
    emit("```\n\n")
    emit("The keys become column headers, and each object becomes a row!")

elif "sort" in lower(user_msg):
    emit("Sorting data patterns:\n\n")
    emit("**Ascending (A-Z, 0-9):**\n")
    emit("```\n")
    emit("sorted(data)                  # Simple sort\n")
    emit("sorted(data, key: 'name')     # Sort by field\n")
    emit("```\n\n")
    emit("**Descending (Z-A, 9-0):**\n")
    emit("```\n")
    emit("sorted(data, reverse: true)\n")
    emit("```\n\n")
    emit("**Custom sort:**\n")
    emit("```\n")
    emit("sorted(users, key: (u) -> get(u, 'age'))\n")
    emit("```\n\n")
    emit("What data would you like to sort?")

elif "filter" in lower(user_msg):
    emit("Filtering data patterns:\n\n")
    emit("**Filter by condition:**\n")
    emit("```\n")
    emit("# Keep items matching condition\n")
    emit("adults = filter(users, (u) -> get(u, 'age') >= 18)\n\n")
    emit("# Remove items matching condition\n")
    emit("non_empty = reject(items, (x) -> is_empty(x))\n")
    emit("```\n\n")
    emit("**Filter by value:**\n")
    emit("```\n")
    emit("# Find specific items\n")
    emit("admins = filter(users, (u) -> get(u, 'role') == 'admin')\n")
    emit("```\n\n")
    emit("What would you like to filter?")

elif "group" in lower(user_msg):
    emit("Grouping data patterns:\n\n")
    emit("**Group by field:**\n")
    emit("```\n")
    emit("users = [{name: 'Alice', dept: 'Engineering'}, {name: 'Bob', dept: 'Sales'}, {name: 'Carol', dept: 'Engineering'}]\n\n")
    emit("by_dept = group_by(users, (u) -> get(u, 'dept'))\n")
    emit("# Result: {Engineering: [...], Sales: [...]}\n")
    emit("```\n\n")
    emit("**Partition (split into two groups):**\n")
    emit("```\n")
    emit("even_odd = partition(numbers, (n) -> n % 2 == 0)\n")
    emit("# Result: [[evens], [odds]]\n")
    emit("```")

elif "transform" in lower(user_msg) or "map" in lower(user_msg):
    emit("Transforming data patterns:\n\n")
    emit("**Map (transform each item):**\n")
    emit("```\n")
    emit("# Double all numbers\n")
    emit("doubled = map(numbers, (n) -> n * 2)\n\n")
    emit("# Extract field from objects\n")
    emit("names = map(users, (u) -> get(u, 'name'))\n\n")
    emit("# Add computed field\n")
    emit("enriched = map(orders, (o) -> merge(o, {total: get(o, 'price') * get(o, 'qty')}))\n")
    emit("```\n\n")
    emit("What transformation do you need?")

elif "aggregate" in lower(user_msg) or "sum" in lower(user_msg) or "count" in lower(user_msg):
    emit("Aggregating data patterns:\n\n")
    emit("**Count:**\n")
    emit("```\n")
    emit("total_items = len(data)\n")
    emit("matching = len(filter(data, predicate))\n")
    emit("```\n\n")
    emit("**Sum:**\n")
    emit("```\n")
    emit("total = sum(numbers)\n")
    emit("total_sales = sum(map(orders, (o) -> get(o, 'amount')))\n")
    emit("```\n\n")
    emit("**Statistics:**\n")
    emit("```\n")
    emit("average = avg(numbers)\n")
    emit("minimum = min(numbers)\n")
    emit("maximum = max(numbers)\n")
    emit("```")

elif "merge" in lower(user_msg) or "combine" in lower(user_msg):
    emit("Merging data patterns:\n\n")
    emit("**Merge maps:**\n")
    emit("```\n")
    emit("defaults = {theme: 'light', lang: 'en'}\n")
    emit("user_prefs = {theme: 'dark'}\n")
    emit("final = merge(defaults, user_prefs)\n")
    emit("# Result: {theme: 'dark', lang: 'en'}\n")
    emit("```\n\n")
    emit("**Combine lists:**\n")
    emit("```\n")
    emit("all_items = concat(list1, list2, list3)\n")
    emit("```\n\n")
    emit("**Zip lists together:**\n")
    emit("```\n")
    emit("names = ['Alice', 'Bob']\n")
    emit("ages = [30, 25]\n")
    emit("combined = zip(names, ages)\n")
    emit("# Result: [['Alice', 30], ['Bob', 25]]\n")
    emit("```")

elif "flatten" in lower(user_msg):
    emit("Flattening nested data:\n\n")
    emit("**Flatten nested lists:**\n")
    emit("```\n")
    emit("nested = [[1, 2], [3, 4], [5, 6]]\n")
    emit("flat = flatten(nested)\n")
    emit("# Result: [1, 2, 3, 4, 5, 6]\n")
    emit("```\n\n")
    emit("**Flat map (map + flatten):**\n")
    emit("```\n")
    emit("sentences = ['Hello World', 'SLOP Rocks']\n")
    emit("all_words = flat_map(sentences, (s) -> split(s, ' '))\n")
    emit("# Result: ['Hello', 'World', 'SLOP', 'Rocks']\n")
    emit("```")

elif "unique" in lower(user_msg) or "distinct" in lower(user_msg) or "duplicate" in lower(user_msg):
    emit("Handling duplicates:\n\n")
    emit("**Get unique values:**\n")
    emit("```\n")
    emit("data = [1, 2, 2, 3, 3, 3, 4]\n")
    emit("distinct = unique(data)\n")
    emit("# Result: [1, 2, 3, 4]\n")
    emit("```\n\n")
    emit("**Remove consecutive duplicates:**\n")
    emit("```\n")
    emit("dedup(data, by: key_fn)\n")
    emit("```\n\n")
    emit("**Using sets:**\n")
    emit("```\n")
    emit("unique_set = set(data)\n")
    emit("# Sets automatically contain only unique values\n")
    emit("```")

else:
    emit("I'm your Data Helper!\n\n")
    emit("I can help with data transformation patterns:\n")
    emit("- **Sorting** - Order your data\n")
    emit("- **Filtering** - Select matching items\n")
    emit("- **Grouping** - Categorize data\n")
    emit("- **Transforming** - Map and modify items\n")
    emit("- **Aggregating** - Sum, count, average\n")
    emit("- **Merging** - Combine data sources\n")
    emit("- **Flattening** - Simplify nested data\n")
    emit("- **Deduplication** - Remove duplicates\n")
    emit("- **Format conversion** - JSON, CSV, etc.\n\n")
    emit("Just ask about any data operation!")
